{
  "name": "daydream",
  "version": "1.0.0",
  "description": "像素眼睛专注计时器 — 让工作更专注",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir",
    "icon": "node scripts/generate-icon.js"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.8",
    "pngjs": "^7.0.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "io.daydream.focus",
    "productName": "Daydream",
    "files": [
      "**/*",
      "!node_modules/**/.bin/**",
      "!*.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true
    }
  }
}
